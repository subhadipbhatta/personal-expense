{
  "name": "anukul-whatsapp-assistant",
  "version": "2.0.0",
  "description": "All-in-one WhatsApp assistant for managing expenses, scheduling events, creating polls, and setting reminders",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "assistant",
    "expense",
    "calendar",
    "polls",
    "reminders",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@whiskeysockets/baileys": "^6.7.0",
    "axios": "^1.6.7",
    "chrono-node": "^2.9.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "ics": "^3.11.0",
    "mongoose": "^8.2.0",
    "node-cron": "^4.2.1",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
