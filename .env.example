# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/expense-splitter

# Bot Configuration
BOT_NAME=Anukul
BOT_TRIGGER=@anukul

# Server Configuration
PORT=3002
NODE_ENV=development

# Conversational AI (HIGHLY RECOMMENDED!)
# Get your API key from: https://console.anthropic.com/settings/keys
# With this enabled, Anukul becomes a truly conversational assistant!
ANTHROPIC_API_KEY=your_api_key_here

# 🤖 WITH CONVERSATIONAL AI ENABLED:
# Anukul is a friendly, intelligent assistant you can chat with naturally:
#
# • Natural Conversations:
#   "@anukul hey! how are you?"
#   "@anukul what can you help with?"
#   "@anukul thanks for your help!"
#
# • Natural Language Expenses:
#   "@anukul I paid 50 for lunch with john"
#   "@anukul add my dinner expense of $30"
#   "@anukul sarah paid me back 20 bucks"
#
# • Smart Analysis & Insights:
#   "@anukul how much have we spent on food?"
#   "@anukul summarize our expenses this month"
#   "@anukul who owes the most?"
#   "@anukul give me spending insights"
#
# • Expense Management Expert:
#   All expenses synced to Splitwise cloud
#   Real-time balance calculations
#   Access via Splitwise web/mobile apps
#
# 📝 WITHOUT AI (Rule-based mode):
# Commands must be structured:
#   "@anukul add expense $50 lunch"
#   "@anukul balance"
#   Still works, but less friendly and no conversations
#
# 💰 Cost: ~$1-3/month for typical group usage (~150 AI queries)
# 🚀 Worth it for the conversational experience!

# Splitwise Integration (Required for expense management via Splitwise)
# Get credentials by running: cd src && python3 -m splitwise_mcp_server.oauth_setup
# Or manually from: https://secure.splitwise.com/apps
SPLITWISE_OAUTH_CONSUMER_KEY=your_consumer_key_here
SPLITWISE_OAUTH_CONSUMER_SECRET=your_consumer_secret_here
SPLITWISE_OAUTH_ACCESS_TOKEN=your_access_token_here

# Splitwise Configuration
SPLITWISE_CACHE_TTL=86400
SPLITWISE_MATCH_THRESHOLD=70
